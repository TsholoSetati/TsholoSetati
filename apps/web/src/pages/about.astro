---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { site } from '~/config/site';
---

<BaseLayout seo={{ title: 'About', description: 'Background, focus areas and credentials of Tsholofelo K. Setati.' }}>
  <section class="container section about">
    <header class="about-head" data-reveal>
      <img src="/assets/profile.jpg" alt="Tsholofelo K. Setati" class="portrait" loading="eager" />
      <div>
        <p class="eyebrow">About</p>
        <h1>Tsholofelo K. Setati</h1>
        <p class="tagline">
          Working at the intersection of AI, technology economics and institutional governance, across enterprise, public sector and civic contexts.
        </p>
      </div>
    </header>

    <div class="prose" data-reveal>
      <p>
        My background combines PhD-level economic training with deep, hands-on expertise in AI architecture,
        MLOps, and cloud platforms. That combination lets me read frontier technology through three lenses
        at once, the economics that determine whether it compounds value, the governance that determines
        whether it can be trusted, and the architecture that determines whether it actually ships.
      </p>
      <p>
        I work across enterprise, public sector, multilateral and non-profit contexts on AI and technology
        governance, frontier technology transformation, innovation economics, cloud FinSecOps, automation
        and cross-sector strategy. The output is writing, advisory work, and the occasional diagnostic
        prototype, not a service catalogue.
      </p>
    </div>

    <div class="about-grid" data-reveal>
      <div class="card">
        <h3>Areas of expertise</h3>
        <ul>
          <li>AI &amp; technology governance</li>
          <li>Innovation economics &amp; value realisation</li>
          <li>Frontier technology transformation</li>
          <li>Cloud FinSecOps &amp; technology economics</li>
          <li>Cross-sector strategy</li>
        </ul>
      </div>
      <div class="card">
        <h3>Background</h3>
        <ul>
          <li>PhD candidate, Innovation Economics</li>
          <li>Currently: Senior Cloud &amp; AI Solution Engineer at a global hyperscaler (Big Tech), MEA</li>
          <li>Former technology consulting at a Big 4 professional services firm</li>
          <li>Economic &amp; quantitative research at leading South African research institutions</li>
        </ul>
      </div>
      <div class="card">
        <h3>Based in</h3>
        <p>{site.author.location}. Working with clients across Africa, the Middle East and Europe.</p>
        <p><a class="link-arrow" href="/contact">Start a conversation →</a></p>
      </div>
    </div>

    <aside class="career-arc" data-reveal>
      <div class="career-arc-inner">
        <div class="career-arc-copy">
          <p class="eyebrow">Career arc</p>
          <h3>Quantitative research → Big 4 consulting → enterprise AI leadership.</h3>
          <p class="muted">
            A career that started in economic research at South African policy think-tanks, moved through
            end-to-end digital transformation programmes at a Big 4 firm, and now sits at the C-suite end
            of frontier AI engagements at a global hyperscaler across Middle East and Africa.
          </p>
          <p><a class="link-arrow" href="/experience">Read the full timeline →</a></p>
        </div>
        <ol class="career-arc-rail">
          <li><span class="rail-dot"></span><span>Economic & quantitative research</span></li>
          <li><span class="rail-dot"></span><span>Technology consulting (Big 4)</span></li>
          <li><span class="rail-dot"></span><span>Cross-Solution Architect, Africa</span></li>
          <li><span class="rail-dot rail-dot-active"></span><span>Senior Cloud & AI Solution Engineer, MEA</span></li>
        </ol>
      </div>
    </aside>
  </section>
</BaseLayout>

<style>
  .about-head { display: grid; grid-template-columns: auto 1fr; gap: 2rem; align-items: center; margin-bottom: 3rem; }
  .portrait { width: 160px; height: 160px; border-radius: 50%; object-fit: cover; box-shadow: var(--shadow-lg); }
  .eyebrow { font-family: var(--font-mono); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-ink-tertiary); margin: 0 0 0.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 0.5rem; }
  .tagline { color: var(--color-ink-secondary); font-size: var(--font-lg); margin: 0; max-width: 50ch; }
  .prose { max-width: 70ch; margin: 0 auto 3rem; }
  .prose p { line-height: 1.7; margin: 0 0 1rem; color: var(--color-ink-secondary); }
  .about-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .about-grid h3 { font-family: var(--font-display); margin: 0 0 0.75rem; }
  .about-grid ul { padding-left: 1.1rem; margin: 0; color: var(--color-ink-secondary); }
  .about-grid ul li { margin-bottom: 0.4rem; }
  .link-arrow { color: var(--color-accent); }
  @media (max-width: 640px) {
    .about-head { grid-template-columns: 1fr; text-align: center; }
    .portrait { margin: 0 auto; width: 140px; height: 140px; }
  }

  .career-arc {
    margin-top: 3rem;
    padding: 2rem;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border-subtle);
    border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
  }
  .career-arc-inner { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2.5rem; align-items: center; }
  .career-arc-copy h3 { font-family: var(--font-display); font-weight: 500; font-size: 1.4rem; line-height: 1.25; margin: 0 0 0.85rem; color: var(--color-ink-primary); }
  .career-arc-copy .muted { color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; }
  .career-arc-rail { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.55rem; position: relative; }
  .career-arc-rail::before { content: ''; position: absolute; left: 5px; top: 6px; bottom: 6px; width: 1px; background: var(--color-border-default); }
  .career-arc-rail li { display: grid; grid-template-columns: auto 1fr; gap: 0.75rem; align-items: center; font-size: 0.92rem; color: var(--color-ink-secondary); }
  .rail-dot { width: 11px; height: 11px; border-radius: 50%; background: var(--color-surface-base); border: 2px solid var(--color-border-default); position: relative; z-index: 1; }
  .rail-dot-active { background: var(--color-accent); border-color: var(--color-accent); box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12); }
  .career-arc-rail li:last-child { color: var(--color-ink-primary); font-weight: 500; }
  @media (max-width: 720px) {
    .career-arc-inner { grid-template-columns: 1fr; gap: 1.5rem; }
  }
</style>

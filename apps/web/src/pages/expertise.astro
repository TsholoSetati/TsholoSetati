---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { capabilities } from '~/data/capabilities';
---

<BaseLayout seo={{ title: 'Expertise', description: 'Domains of expertise across AI & technology governance, frontier technology transformation, innovation economics, technology economics, cloud FinSecOps, automation, and cross-sector strategy.' }}>
  <section class="container section">
    <header data-reveal>
      <p class="eyebrow">Areas of Expertise</p>
      <h1>Where I work, write and think in public.</h1>
      <p class="lead">
        These are the domains I have built depth in across enterprise, government, multilateral and non-profit
        contexts. They are not a service catalogue — they are the lenses through which I read the technology,
        economics and governance questions facing institutions today.
      </p>
    </header>

    <div class="grid">
      {capabilities.map((c, i) => (
        <article class="cap card" data-reveal>
          <p class="num">0{i + 1}</p>
          <h2>{c.title}</h2>
          <p class="summary">{c.summary}</p>
          <ul>
            {c.bullets.map((b) => <li>{b}</li>)}
          </ul>
        </article>
      ))}
    </div>

    <div class="cta-band" data-reveal>
      <div class="cta-inner">
        <h2>Want to compare notes?</h2>
        <p>I write, speak and advise across these areas. If your work intersects with any of them, get in touch.</p>
        <a class="btn btn-primary" href="/contact">Get in touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .eyebrow { font-family: var(--font-mono); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.14em; color: var(--color-ink-tertiary); margin: 0 0 0.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 1rem; max-width: 22ch; }
  .lead { color: var(--color-ink-secondary); font-size: var(--font-lg); max-width: 60ch; margin: 0 0 3rem; line-height: 1.6; }
  .grid { display: grid; gap: 1.25rem; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); margin-bottom: 3rem; }
  .cap { display: flex; flex-direction: column; }
  .num { font-family: var(--font-mono); color: var(--color-accent); font-size: var(--font-sm); margin: 0 0 0.5rem; }
  .cap h2 { font-family: var(--font-display); font-size: var(--font-xl); margin: 0 0 0.75rem; }
  .summary { color: var(--color-ink-secondary); line-height: 1.6; margin: 0 0 1rem; }
  .cap ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.4rem; }
  .cap li { padding-left: 1.1rem; position: relative; font-size: var(--font-sm); color: var(--color-ink-secondary); }
  .cap li::before { content: ''; position: absolute; left: 0; top: 0.55em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); }
  .cta-band { padding: clamp(1.75rem, 5vw, 2.5rem); border-radius: var(--radius-xl); background: linear-gradient(120deg, var(--color-accent), var(--color-accent-2)); color: white; text-align: center; }
  .cta-inner h2 { font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2rem); margin: 0 0 0.5rem; color: white; }
  .cta-inner p { color: rgba(255,255,255,0.85); margin: 0 0 1.25rem; font-size: clamp(0.95rem, 1.6vw, 1.05rem); }
</style>

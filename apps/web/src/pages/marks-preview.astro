---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Mark from '~/components/Mark.astro';

type WaveId =
  | 'wave-trio' | 'wave-quad' | 'wave-quintet' | 'wave-fade' | 'wave-bold'
  | 'wave-arrow' | 'wave-time' | 'wave-eq-trail' | 'wave-axes' | 'wave-spread'
  | 'wave-scurve' | 'wave-scurve-fade' | 'wave-bell' | 'wave-bell-stack' | 'wave-logistic'
  | 'wave-skew' | 'wave-arch' | 'wave-dome' | 'wave-hill' | 'wave-crescent'
  | 'wave-ripple' | 'wave-pulse' | 'wave-sonar' | 'wave-halo' | 'wave-orbit'
  | 'wave-radial' | 'wave-burst' | 'wave-echo' | 'wave-shock' | 'wave-broadcast'
  | 'wave-sine' | 'wave-sine-stack' | 'wave-sine-grow' | 'wave-sine-freq' | 'wave-cycle'
  | 'wave-double' | 'wave-pulse-train' | 'wave-zigzag' | 'wave-damped' | 'wave-beat'
  | 'wave-tsunami' | 'wave-strata' | 'wave-mountain' | 'wave-tide' | 'wave-crest'
  | 'wave-spectrum' | 'wave-cascade' | 'wave-river' | 'wave-pillar' | 'wave-pulse-dot';

const families: { name: string; intro: string; items: { id: WaveId; name: string; note: string }[] }[] = [
  {
    name: 'A · Shift variants',
    intro: 'Innovation as successive demand shifts. Each new wave moves the curve outward; older waves linger as faded predecessors. The classical S/D reading.',
    items: [
      { id: 'wave-trio', name: 'Trio', note: 'Three demand curves, opacity ramping faint→solid. The canonical reading.' },
      { id: 'wave-quad', name: 'Quartet', note: 'Four demand shifts. Denser stack, more historical depth.' },
      { id: 'wave-quintet', name: 'Quintet', note: 'Five waves with stroke-weight also growing. Adds weight gradient on top of opacity.' },
      { id: 'wave-fade', name: 'Long fade', note: 'Eight curves trailing into the past. Reads as deep history of innovation, not just three generations.' },
      { id: 'wave-bold', name: 'Bold trio', note: 'Three equal-weight curves. Reads as confident peer waves rather than a hierarchy.' },
      { id: 'wave-arrow', name: 'Trio + arrow', note: 'Three shifts with a horizontal directional arrow above. Spells out the direction of travel.' },
      { id: 'wave-time', name: 'Trio + timeline', note: 'Three shifts plus tick marks below. Anchors the waves to time explicitly.' },
      { id: 'wave-eq-trail', name: 'Equilibrium trail', note: 'Three curves with three equilibrium dots connected by a dotted path. The eye follows the equilibrium walking outward.' },
      { id: 'wave-axes', name: 'On full axes', note: 'Three shifts framed by P/Q axes. Most chart-like, most academic.' },
      { id: 'wave-spread', name: 'Fan from origin', note: 'Three lines fanning from one point. Reads as divergent futures from a common starting condition.' },
    ],
  },
  {
    name: 'B · Curves & bells',
    intro: 'Wave-shaped demand: not just a line shift, a different functional form. S-curves, bell curves, logistics — the actual functions used to model adoption.',
    items: [
      { id: 'wave-scurve', name: 'S-curves', note: 'Three Rogers/Bass adoption curves stacked. Each generation completes its diffusion before the next begins.' },
      { id: 'wave-scurve-fade', name: 'S-curves long fade', note: 'Four S-curves with the deepest faded. History of adoption cycles.' },
      { id: 'wave-bell', name: 'Bell curves rightward', note: 'Three bell curves marching right with growing height. Each wave wider, taller, later.' },
      { id: 'wave-bell-stack', name: 'Bell curves stacked', note: 'Three bells centered on the same x — successive waves all peaking on the present.' },
      { id: 'wave-logistic', name: 'Logistics rightward', note: 'Three logistic adoption curves shifted right. Each wave\'s saturation comes later.' },
      { id: 'wave-skew', name: 'Skewed adoption', note: 'Two right-skewed curves — fast peak, long tail. The realistic shape of innovation diffusion.' },
      { id: 'wave-arch', name: 'Receding arches', note: 'Three concentric semicircles. Architectural, monumental — innovation as a built form.' },
      { id: 'wave-dome', name: 'Concentric domes', note: 'Three nested domes; tallest is widest. Reads as canopy or aurora.' },
      { id: 'wave-hill', name: 'Receding hills', note: 'Three rolling hill silhouettes. Pastoral, organic, geological time.' },
      { id: 'wave-crescent', name: 'Crescent waves', note: 'Three rising crescents. Lyrical, almost calligraphic.' },
    ],
  },
  {
    name: 'C · Concentric & radial',
    intro: 'Innovation as something that radiates from a source. Ripples, sonar pings, broadcast arcs — the metaphor of diffusion through space.',
    items: [
      { id: 'wave-ripple', name: 'Ripple from edge', note: 'Three half-arcs opening rightward from a source dot. Pure ripple imagery.' },
      { id: 'wave-pulse', name: 'Pulse from centre', note: 'Concentric circles around a central dot. Symmetric, broadcast in all directions.' },
      { id: 'wave-sonar', name: 'Sonar ping', note: 'Quarter-arcs from the bottom-left corner. Active scanning, exploration.' },
      { id: 'wave-halo', name: 'Concentric halo', note: 'Nested ellipses — a vertical halo. Reads as aura, light source.' },
      { id: 'wave-orbit', name: 'Orbit', note: 'Three rotated orbits crossing through a central node. Reads as atom, planetary motion, hub.' },
      { id: 'wave-radial', name: 'Radial fan', note: 'Five lines fanning from a corner point. Reads as searchlight, lighthouse, attention.' },
      { id: 'wave-burst', name: 'Sunburst', note: 'Twelve rays from centre, alternating weight. Maximum dispersal, maximum energy.' },
      { id: 'wave-echo', name: 'Echo trail', note: 'Four overlapping circles marching rightward; opacity ramps up. Reads as motion blur, echo.' },
      { id: 'wave-shock', name: 'Shockwave', note: 'Central dot with concentric shock rings, dashed. Reads as detonation, sudden impact.' },
      { id: 'wave-broadcast', name: 'Broadcast antenna', note: 'Vertical antenna with three radiating arcs above. Literal broadcast metaphor.' },
    ],
  },
  {
    name: 'D · Sine & oscillating',
    intro: 'Innovation as oscillation, cycle, frequency. Schumpeter, Kondratiev, signal processing.',
    items: [
      { id: 'wave-sine', name: 'Sine wave', note: 'A single clean sine. The most abstract, the most universal.' },
      { id: 'wave-sine-stack', name: 'Three sines stacked', note: 'Three parallel sines. Layered cycles — short, medium, long waves co-existing.' },
      { id: 'wave-sine-grow', name: 'Growing amplitude', note: 'Sine with amplitude rising left→right. Each cycle larger than the last.' },
      { id: 'wave-sine-freq', name: 'Rising frequency', note: 'Sine with frequency increasing rightward. Acceleration of innovation cycles — the Kurzweil reading.' },
      { id: 'wave-cycle', name: 'Long wave', note: 'One full Kondratiev cycle — peak, trough — with phase markers. Schumpeterian.' },
      { id: 'wave-double', name: 'Double sine', note: 'Two interleaved sines. Two competing or complementary cycles.' },
      { id: 'wave-pulse-train', name: 'Square pulses', note: 'Square-wave pulses. Digital, on/off, binary-paradigm waves.' },
      { id: 'wave-zigzag', name: 'Sawtooth', note: 'Three sawtooth peaks. Sharp rises, instant resets — boom-bust pattern.' },
      { id: 'wave-damped', name: 'Damped oscillation', note: 'Big amplitude left, decaying right. Innovation that overshoots then settles.' },
      { id: 'wave-beat', name: 'Beat pattern', note: 'Two close-frequency sines superimposed. Interference between competing waves.' },
    ],
  },
  {
    name: 'E · Metaphorical',
    intro: 'Pictorial readings: tsunami, strata, mountain, tide, river, spectrum. Less chart, more icon.',
    items: [
      { id: 'wave-tsunami', name: 'Tsunami', note: 'Trough then towering crest. Disruptive innovation as a single overwhelming wave.' },
      { id: 'wave-strata', name: 'Geological strata', note: 'Four horizontal bands. Innovation as sedimentary layers, history accumulating.' },
      { id: 'wave-mountain', name: 'Mountain ranges', note: 'Three receding ridge lines. Depth-of-field landscape — past waves still visible.' },
      { id: 'wave-tide', name: 'Tide ridges', note: 'Three gentle horizontal sine ridges. Calm, reliable, periodic.' },
      { id: 'wave-crest', name: 'Breaking crests', note: 'Three breaking-wave shapes rising. Surfer-friendly, kinetic.' },
      { id: 'wave-spectrum', name: 'Spectrum bars', note: 'Seven vertical bars rising left→right. Equaliser, audio-spectrum, energy bands.' },
      { id: 'wave-cascade', name: 'Cascade staircase', note: 'Descending step function. Innovation as cost staircase falling over time.' },
      { id: 'wave-river', name: 'Meandering river', note: 'A single sinuous line. Innovation as a flow with a memory of its path.' },
      { id: 'wave-pillar', name: 'Rising pillars', note: 'Four bars of growing height with a dashed trendline. Reads as forecast, accumulated capacity.' },
      { id: 'wave-pulse-dot', name: 'Pulse + traveller', note: 'Flatline, then a single ECG-style pulse, then a dot continuing. Innovation as a single discrete event in a stream.' },
    ],
  },
];
---

<BaseLayout seo={{ title: 'Marks · waves', description: 'Scratch page exploring 50 logo variations of the innovation-waves concept.' }}>
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  <section class="container section">
    <header data-reveal>
      <p class="eyebrow">Round 6 · innovation waves, 50 ways</p>
      <h1>Fifty variations on a single idea: innovation arrives in waves.</h1>
      <p class="lead">
        Same concept — innovation as successive market shifts — fifty visual treatments. Five families
        of ten: classical S/D shifts, function-shape curves, concentric/radial diffusion,
        sine/oscillation, and metaphorical icons. Reply with any <code>id</code> to lock or hybridise.
      </p>
    </header>

    {families.map((fam) => (
      <section class="family" data-reveal>
        <header class="family-head">
          <p class="block-eyebrow">{fam.name}</p>
          <p class="family-intro">{fam.intro}</p>
        </header>

        <div class="grid">
          {fam.items.map((it) => (
            <article class="card">
              <div class="hero light">
                <Mark id={it.id} size={72} />
              </div>
              <div class="meta">
                <p class="name">{it.name}</p>
                <p class="id"><code>{it.id}</code></p>
                <p class="note">{it.note}</p>
                <div class="sizes">
                  <Mark id={it.id} size={16} />
                  <Mark id={it.id} size={28} />
                  <span class="dark"><Mark id={it.id} size={28} /></span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}

    <p class="hint">
      <code>/marks-preview</code> is unlisted (noindex, not in nav). Reply with the chosen id and I&rsquo;ll roll it out.
    </p>
  </section>
</BaseLayout>

<style>
  .eyebrow { font-family: var(--font-mono); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.18em; color: var(--color-ink-tertiary); margin: 0 0 0.5rem; }
  h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); margin: 0 0 1rem; line-height: 1.1; }
  .lead { color: var(--color-ink-secondary); max-width: 70ch; margin: 0 0 3rem; line-height: 1.6; }
  code { font-family: var(--font-mono); font-size: 0.88em; background: var(--color-surface-sunken); padding: 0.05em 0.35em; border-radius: var(--radius-xs); }

  .family { margin: 0 0 4rem; }
  .family-head { margin: 0 0 1.5rem; padding: 0 0 1rem; border-bottom: 1px solid var(--color-border-subtle); }
  .block-eyebrow { font-family: var(--font-mono); font-size: var(--font-xs); text-transform: uppercase; letter-spacing: 0.2em; color: var(--color-accent); margin: 0 0 0.4rem; }
  .family-intro { color: var(--color-ink-secondary); margin: 0; max-width: 70ch; line-height: 1.55; font-size: var(--font-sm); }

  .grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }

  .card { display: flex; flex-direction: column; border: 1px solid var(--color-border-subtle); border-radius: var(--radius-md); overflow: hidden; background: var(--color-surface); }

  .hero { display: flex; align-items: center; justify-content: center; padding: 1.5rem; min-height: 110px; }
  .hero.light { background: #fafaf7; color: #111; }

  .meta { padding: 0.85rem 1rem 1rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .name { font-family: var(--font-display); font-size: var(--font-md); margin: 0; }
  .id { font-size: var(--font-xs); color: var(--color-ink-tertiary); margin: 0; }
  .note { font-size: var(--font-xs); color: var(--color-ink-secondary); margin: 0.2rem 0 0.6rem; line-height: 1.45; }

  .sizes { display: flex; align-items: center; gap: 0.6rem; margin-top: auto; padding-top: 0.4rem; border-top: 1px dashed var(--color-border-subtle); color: var(--color-ink-secondary); }
  .dark { display: inline-flex; padding: 0.25rem 0.4rem; background: #111; color: #fafaf7; border-radius: var(--radius-xs); }

  .hint { margin: 3rem 0 0; color: var(--color-ink-tertiary); font-size: var(--font-sm); }
</style>

---
/**
 * BaseLayout — root document for every page.
 * Handles meta, fonts, theme init (no FOUC), structured data, header/footer, motion bootstrap.
 */
import '~/styles/global.css';
import SiteHeader from '~/components/nav/SiteHeader.astro';
import SiteFooter from '~/components/nav/SiteFooter.astro';
import CommandPalette from '~/components/nav/CommandPalette.astro';
import IntroOverlay from '~/components/IntroOverlay.astro';
import { site } from '~/config/site';
import { features, integrations } from '~/config/features';
import { themeInitScript } from '~/lib/theme-init';
import { pageTitle, jsonLdPerson, jsonLdWebsite } from '~/lib/seo';
import type { SeoMeta } from '~/lib/seo';
import { ClientRouter } from 'astro:transitions';

export interface Props {
  seo?: Partial<SeoMeta>;
  /** When true, hide the header (e.g., for fullscreen demo views). */
  bare?: boolean;
  /** Extra JSON-LD blocks to inject. */
  jsonLd?: Array<Record<string, unknown>>;
  /** Body classes. */
  class?: string;
}

const { seo = {}, bare = false, jsonLd = [], class: bodyClass = '' } = Astro.props;

const title = pageTitle(seo.title);
const description = seo.description ?? site.description;
const canonical = seo.canonical ?? new URL(Astro.url.pathname, site.url).toString();
const ogImage = seo.ogImage ?? `${site.url}/assets/og-default.png`;
const ogType = seo.ogType ?? 'website';

const structuredData = [jsonLdPerson(), jsonLdWebsite(), ...jsonLd];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {seo.keywords && <meta name="keywords" content={seo.keywords.join(', ')} />}
    <link rel="canonical" href={canonical} />
    {seo.noindex && <meta name="robots" content="noindex, nofollow" />}

    {/* Theme color reflects the current surface for OS chrome */}
    <meta name="theme-color" content={site.themeColor} media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

    {/* Open Graph */}
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={site.locale} />
    {ogType === 'article' && seo.publishedTime && (
      <meta property="article:published_time" content={seo.publishedTime} />
    )}
    {ogType === 'article' && seo.modifiedTime && (
      <meta property="article:modified_time" content={seo.modifiedTime} />
    )}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* Favicons */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    {/* Preconnect for Clash Display CDN (other fonts are self-hosted) */}
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />

    {/* RSS */}
    <link rel="alternate" type="application/rss+xml" title={site.name} href="/rss.xml" />

    {/* No-FOUC theme init */}
    <script is:inline set:html={themeInitScript} />

    {/* Structured data */}
    {structuredData.map((data) => (
      <script type="application/ld+json" set:html={JSON.stringify(data)} />
    ))}

    {/* Plausible analytics */}
    {features.plausible && integrations.plausibleDomain && (
      <script
        is:inline
        defer
        data-domain={integrations.plausibleDomain}
        src="https://plausible.io/js/script.js"
      />
    )}

    {/* View transitions */}
    <ClientRouter fallback="swap" />
  </head>

  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to main content</a>
    {!bare && <SiteHeader />}
    <main id="main" tabindex="-1">
      <slot />
    </main>
    {!bare && <SiteFooter />}
    {!bare && <CommandPalette />}
    {!bare && <IntroOverlay />}

    {/* Motion bootstrap — runs once after first paint, re-binds after view transitions */}
    <script>
      import { initMotion } from '~/lib/motion';
      initMotion();
    </script>
  </body>
</html>

<style>
  main {
    min-height: 60vh;
  }
  main:focus {
    outline: none;
  }
</style>

---
/**
 * IntroOverlay — first-visit welcome shown once per browser.
 *
 * Renders nothing in the SSR HTML beyond a hidden dialog. The script
 * checks localStorage for `ts:intro-seen`; if absent and the visitor
 * hasn't asked for reduced motion, the overlay is unhidden after a
 * short delay so it doesn't fight the initial paint.
 *
 * Three quick-start tiles route to About, Demos, and Insights — the
 * most useful entry points for a new visitor. A dismiss button writes
 * the localStorage flag so it never shows again.
 *
 * Mounted from BaseLayout when `bare` is false, so demo iframes and
 * other chrome-less surfaces are unaffected.
 */
import { Icon } from 'astro-icon/components';
import { site } from '~/config/site';
---

<div class="intro" data-intro hidden role="dialog" aria-modal="true" aria-labelledby="intro-title">
  <div class="intro-backdrop" data-intro-dismiss></div>
  <div class="intro-panel" tabindex="-1">
    <button class="intro-close" data-intro-dismiss aria-label="Close welcome">
      <Icon name="ph:x" aria-hidden="true" />
    </button>

    <p class="intro-eyebrow">Welcome</p>
    <h2 id="intro-title" class="intro-title">{site.name}</h2>
    <p class="intro-tagline">{site.tagline}</p>
    <p class="intro-lede">
      Translating emerging technology into compounding business advantage —
      with field notes, working demos and a clear point of view.
    </p>

    <div class="intro-tiles">
      <a class="intro-tile" href="/about" data-intro-dismiss-on-click>
        <Icon name="ph:user-focus" aria-hidden="true" />
        <span class="intro-tile-title">Who I am</span>
        <span class="intro-tile-sub">Background and how I work</span>
      </a>
      <a class="intro-tile" href="/demos" data-intro-dismiss-on-click>
        <Icon name="ph:flask" aria-hidden="true" />
        <span class="intro-tile-title">Working demos</span>
        <span class="intro-tile-sub">Prototypes you can open in the browser</span>
      </a>
      <a class="intro-tile" href="/insights" data-intro-dismiss-on-click>
        <Icon name="ph:newspaper" aria-hidden="true" />
        <span class="intro-tile-title">Field notes</span>
        <span class="intro-tile-sub">Long-form thinking on AI and innovation</span>
      </a>
    </div>

    <div class="intro-foot">
      <button class="intro-btn intro-btn-primary" data-intro-dismiss>Start exploring</button>
      <span class="intro-hint">Press <kbd>⌘K</kbd> any time to search</span>
    </div>
  </div>
</div>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .intro[hidden] { display: none; }
  .intro-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in oklab, var(--color-ink-primary) 55%, transparent);
    backdrop-filter: blur(8px);
    cursor: pointer;
  }
  .intro-panel {
    position: relative;
    width: min(640px, 100%);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl, 0 24px 60px -12px rgba(0,0,0,0.4));
    padding: clamp(1.5rem, 4vw, 2.5rem);
    max-height: 90vh;
    overflow-y: auto;
    animation: intro-pop 280ms cubic-bezier(0.2, 0.9, 0.3, 1.2);
  }
  @keyframes intro-pop {
    from { opacity: 0; transform: translateY(12px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .intro-close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    width: 2rem;
    height: 2rem;
    border-radius: var(--radius-md);
    border: 0;
    background: transparent;
    color: var(--color-ink-tertiary);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 160ms ease, color 160ms ease;
  }
  .intro-close :global(svg) { width: 1.1rem; height: 1.1rem; }
  .intro-close:hover { background: var(--color-surface-sunken); color: var(--color-ink-primary); }
  .intro-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    margin: 0 0 0.5rem;
  }
  .intro-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 2.1rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--color-ink-primary);
    margin: 0 0 0.4rem;
  }
  .intro-tagline {
    font-size: 0.95rem;
    color: var(--color-ink-secondary);
    margin: 0 0 0.85rem;
  }
  .intro-lede {
    font-size: 0.95rem;
    color: var(--color-ink-secondary);
    line-height: 1.6;
    margin: 0 0 1.5rem;
    max-width: 56ch;
  }
  .intro-tiles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }
  .intro-tile {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.95rem 0.85rem;
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-ink-primary);
    text-decoration: none;
    transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }
  .intro-tile :global(svg) {
    width: 1.3rem;
    height: 1.3rem;
    color: var(--color-accent);
    margin-bottom: 0.2rem;
  }
  .intro-tile-title { font-weight: 600; font-size: 0.95rem; }
  .intro-tile-sub { font-size: 0.78rem; color: var(--color-ink-tertiary); line-height: 1.4; }
  .intro-tile:hover {
    border-color: var(--color-accent);
    background: color-mix(in oklab, var(--color-accent) 8%, var(--color-surface-sunken));
    transform: translateY(-2px);
  }
  .intro-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .intro-btn {
    border: 0;
    cursor: pointer;
    padding: 0.7rem 1.2rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.92rem;
    transition: filter 160ms ease, transform 160ms ease;
  }
  .intro-btn-primary {
    background: var(--color-accent);
    color: white;
  }
  .intro-btn-primary:hover { filter: brightness(1.08); transform: translateY(-1px); }
  .intro-hint {
    font-size: 0.78rem;
    color: var(--color-ink-tertiary);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .intro-hint kbd {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    color: var(--color-ink-secondary);
  }

  @media (max-width: 540px) {
    .intro-tiles { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .intro-panel { animation: none; }
    .intro-tile:hover { transform: none; }
    .intro-btn-primary:hover { transform: none; }
  }
</style>

<script>
  const STORAGE_KEY = 'ts:intro-seen-v1';

  function alreadySeen(): boolean {
    try { return localStorage.getItem(STORAGE_KEY) === '1'; } catch { return false; }
  }
  function markSeen(): void {
    try { localStorage.setItem(STORAGE_KEY, '1'); } catch {}
  }

  function setupIntro() {
    const root = document.querySelector<HTMLElement>('[data-intro]');
    if (!root) return;
    if (root.dataset.bound) return;
    root.dataset.bound = 'true';

    if (alreadySeen()) return;

    function show() {
      root.hidden = false;
      // Move focus to the panel so screen readers announce it.
      root.querySelector<HTMLElement>('.intro-panel')?.focus();
      document.body.style.overflow = 'hidden';
    }
    function hide() {
      if (root.hidden) return;
      root.hidden = true;
      document.body.style.overflow = '';
      markSeen();
    }

    root.querySelectorAll<HTMLElement>('[data-intro-dismiss]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        hide();
      });
    });
    root.querySelectorAll<HTMLAnchorElement>('[data-intro-dismiss-on-click]').forEach((a) => {
      a.addEventListener('click', () => {
        markSeen();
        // Allow the navigation to proceed normally.
        root.hidden = true;
        document.body.style.overflow = '';
      });
    });
    document.addEventListener('keydown', (e) => {
      if (!root.hidden && e.key === 'Escape') {
        e.preventDefault();
        hide();
      }
    });

    // Defer just slightly so the page paints first.
    const reduce = window.matchMedia?.('(prefers-reduced-motion: reduce)').matches;
    const delay = reduce ? 0 : 600;
    window.setTimeout(show, delay);
  }

  setupIntro();
  // Note: deliberately NOT re-binding on astro:page-load — the intro
  // should only ever appear on the first visit, not on subsequent
  // in-session navigations.
</script>

---
/**
 * Site mark — inline SVG, monochrome, themed via currentColor.
 * Round 1: prism, monogram, inflection, aperture
 * Round 2 (econ + innovation):
 *   cross       — supply/demand X (price discovery)
 *   compound    — exponential growth curve with tick marks
 *   network     — three-node triangle network (diffusion)
 *   lattice     — 3×3 lattice with one filled node (frontier)
 *   jcurve      — J-shape (reform, adoption dip-then-rise)
 *   wavefront   — three concentric arcs radiating right (diffusion)
 *   threshold   — step function (regime change / tipping point)
 *   arbitrage   — two parallel rails bridged diagonally (spread)
 *   frontier    — convex PPF arc with point on it
 *   sprout      — upward arrow emerging from a baseline (breakout)
 */

type MarkId =
  | 'prism' | 'monogram' | 'inflection' | 'aperture'
  | 'cross' | 'compound' | 'network' | 'lattice' | 'jcurve'
  | 'wavefront' | 'threshold' | 'arbitrage' | 'frontier' | 'sprout'
  // Round 3 — variations
  | 'cross-axes' | 'cross-shift' | 'cross-wedge' | 'cross-arrows' | 'cross-halo'
  | 'inflection-tangent' | 'inflection-twin' | 'inflection-grid' | 'inflection-ribbon' | 'inflection-mirror'
  | 'lattice-path' | 'lattice-spread' | 'lattice-hex' | 'lattice-ring' | 'lattice-pulse'
  | 'frontier-ticks' | 'frontier-dual' | 'frontier-radial' | 'frontier-segments' | 'frontier-shaded';

interface Props {
  id: MarkId;
  size?: number;
  title?: string;
  class?: string;
}

const { id, size = 28, title = 'Tsholo Setati', class: cls = '' } = Astro.props;
const sw = size <= 16 ? 1.6 : size <= 28 ? 1.5 : 1.4;
const common = {
  width: size,
  height: size,
  viewBox: '0 0 24 24',
  fill: 'none' as const,
  role: 'img' as const,
  'aria-label': title,
  class: cls,
  style: 'display:inline-block;vertical-align:middle',
};
---

{id === 'prism' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    role="img"
    aria-label={title}
    class={cls}
    style="display:inline-block;vertical-align:middle"
  >
    {/* incoming ray */}
    <line x1="1.5" y1="12" x2="7.5" y2="12" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* prism: equilateral triangle, apex right */}
    <path d="M7.5 4.5 L7.5 19.5 L20 12 Z" stroke="currentColor" stroke-width={sw} stroke-linejoin="round" fill="none" />
    {/* three refracted beams (top fans up, mid horizontal, bottom fans down) */}
    <line x1="20" y1="12" x2="22.8" y2="7.2" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="20" y1="12" x2="22.8" y2="12" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="20" y1="12" x2="22.8" y2="16.8" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
  </svg>
)}

{id === 'monogram' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    role="img"
    aria-label={title}
    class={cls}
    style="display:inline-block;vertical-align:middle"
  >
    {/* T: horizontal crossbar + vertical stem */}
    <line x1="3" y1="5" x2="21" y2="5" stroke="currentColor" stroke-width={sw * 1.1} stroke-linecap="round" />
    <line x1="12" y1="5" x2="12" y2="21" stroke="currentColor" stroke-width={sw * 1.1} stroke-linecap="round" />
    {/* S: nested arc reading top-right to bottom-left of stem */}
    <path d="M19 9 C 16 9, 14 11, 14 13 C 14 15, 16 17, 19 17" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
  </svg>
)}

{id === 'inflection' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    role="img"
    aria-label={title}
    class={cls}
    style="display:inline-block;vertical-align:middle"
  >
    {/* baseline axis (faint) */}
    <line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="0.8" opacity="0.25" stroke-linecap="round" />
    {/* S-curve crossing axis at midpoint (12,12) */}
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    {/* inflection dot */}
    <circle cx="12" cy="12" r={sw * 1.4} fill="currentColor" />
  </svg>
)}

{id === 'aperture' && (
  <svg
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    role="img"
    aria-label={title}
    class={cls}
    style="display:inline-block;vertical-align:middle"
  >
    {/* Three arcs, 60° apart, forming a soft hexagonal aperture */}
    <g stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none">
      <path d="M6 8 A 8 8 0 0 1 18 8" />
      <path d="M18 8 A 8 8 0 0 1 18 16" />
      <path d="M18 16 A 8 8 0 0 1 6 16" />
      <path d="M6 16 A 8 8 0 0 1 6 8" />
    </g>
    {/* small focal dot */}
    <circle cx="12" cy="12" r={sw * 1.1} fill="currentColor" />
  </svg>
)}

{/* ───── Round 2 — economics + innovation ───── */}

{id === 'cross' && (
  <svg {...common}>
    {/* Supply (rising) and demand (falling) crossing at centre */}
    <line x1="3" y1="20" x2="21" y2="4" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="3" y1="4" x2="21" y2="20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'compound' && (
  <svg {...common}>
    {/* baseline */}
    <line x1="3" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* exponential curve */}
    <path d="M3 20 C 10 20, 14 18, 17 12 S 20 5, 21 3" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    {/* tick milestones */}
    <circle cx="9" cy="19.6" r={sw * 0.7} fill="currentColor" />
    <circle cx="15.5" cy="14.5" r={sw * 0.85} fill="currentColor" />
    <circle cx="20.2" cy="4" r={sw * 1.1} fill="currentColor" />
  </svg>
)}

{id === 'network' && (
  <svg {...common}>
    {/* triangle network: 3 nodes + 3 edges */}
    <line x1="5" y1="19" x2="19" y2="19" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="5" y1="19" x2="12" y2="5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="19" y1="19" x2="12" y2="5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <circle cx="5" cy="19" r={sw * 1.4} fill="currentColor" />
    <circle cx="19" cy="19" r={sw * 1.4} fill="currentColor" />
    <circle cx="12" cy="5" r={sw * 1.7} fill="currentColor" />
  </svg>
)}

{id === 'lattice' && (
  <svg {...common}>
    {/* 3×3 lattice of dots, top-right filled (frontier) */}
    <g fill="currentColor">
      <circle cx="6" cy="18" r={sw * 0.9} opacity="0.4" />
      <circle cx="12" cy="18" r={sw * 0.9} opacity="0.4" />
      <circle cx="18" cy="18" r={sw * 0.9} opacity="0.55" />
      <circle cx="6" cy="12" r={sw * 0.9} opacity="0.4" />
      <circle cx="12" cy="12" r={sw * 0.9} opacity="0.55" />
      <circle cx="18" cy="12" r={sw * 0.9} opacity="0.7" />
      <circle cx="6" cy="6" r={sw * 0.9} opacity="0.55" />
      <circle cx="12" cy="6" r={sw * 0.9} opacity="0.7" />
    </g>
    {/* highlighted frontier node */}
    <circle cx="18" cy="6" r={sw * 1.6} fill="currentColor" />
  </svg>
)}

{id === 'jcurve' && (
  <svg {...common}>
    {/* axis */}
    <line x1="3" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    <line x1="3" y1="20" x2="3" y2="4" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* J: short dip then long rise */}
    <path d="M4 13 C 6 17, 8 19, 10 19 C 14 19, 18 14, 21 4" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <circle cx="10" cy="19" r={sw * 1.1} fill="currentColor" />
  </svg>
)}

{id === 'wavefront' && (
  <svg {...common}>
    {/* origin point */}
    <circle cx="5" cy="12" r={sw * 1.3} fill="currentColor" />
    {/* three concentric arcs propagating right */}
    <g stroke="currentColor" stroke-linecap="round" fill="none">
      <path d="M9 8 A 5 5 0 0 1 9 16" stroke-width={sw} />
      <path d="M13 6 A 8 8 0 0 1 13 18" stroke-width={sw} opacity="0.7" />
      <path d="M17 4 A 11 11 0 0 1 17 20" stroke-width={sw} opacity="0.4" />
    </g>
  </svg>
)}

{id === 'threshold' && (
  <svg {...common}>
    {/* step function: low → jump → high */}
    <path d="M3 17 L 10 17 L 10 7 L 21 7" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" fill="none" />
    {/* tipping point dot */}
    <circle cx="10" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'arbitrage' && (
  <svg {...common}>
    {/* two parallel rails */}
    <line x1="3" y1="7" x2="21" y2="7" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="3" y1="17" x2="21" y2="17" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* diagonal bridge with arrowhead */}
    <line x1="7" y1="17" x2="17" y2="7" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <path d="M17 7 L 13.5 7 M17 7 L 17 10.5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
  </svg>
)}

{id === 'frontier' && (
  <svg {...common}>
    {/* axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* convex production possibility frontier */}
    <path d="M4 4 C 14 4, 20 10, 20 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    {/* efficient point */}
    <circle cx="14.2" cy="7.2" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'sprout' && (
  <svg {...common}>
    {/* baseline */}
    <line x1="3" y1="19" x2="21" y2="19" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* upward stem */}
    <line x1="12" y1="19" x2="12" y2="6" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* arrowhead */}
    <path d="M7 11 L 12 6 L 17 11" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" fill="none" />
    {/* anchor dot at base */}
    <circle cx="12" cy="19" r={sw * 1.1} fill="currentColor" />
  </svg>
)}

{/* ───── Round 3 — variations on cross / inflection / lattice / frontier ───── */}

{/* CROSS family */}
{id === 'cross-axes' && (
  <svg {...common}>
    {/* P (vertical) and Q (horizontal) axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.9" opacity="0.35" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.9" opacity="0.35" stroke-linecap="round" />
    {/* supply (rising) + demand (falling), anchored to axes */}
    <line x1="5" y1="19" x2="20" y2="5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="5" y1="5" x2="20" y2="19" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* equilibrium dotted guides */}
    <line x1="4" y1="12" x2="12.5" y2="12" stroke="currentColor" stroke-width="0.8" stroke-dasharray="1.4 1.6" opacity="0.5" />
    <line x1="12.5" y1="20" x2="12.5" y2="12" stroke="currentColor" stroke-width="0.8" stroke-dasharray="1.4 1.6" opacity="0.5" />
    <circle cx="12.5" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'cross-shift' && (
  <svg {...common}>
    {/* supply line */}
    <line x1="4" y1="19" x2="20" y2="6" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* original demand (faded) */}
    <line x1="4" y1="6" x2="20" y2="19" stroke="currentColor" stroke-width={sw} stroke-linecap="round" opacity="0.32" />
    {/* shifted demand (solid) */}
    <line x1="9" y1="3" x2="22" y2="14" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* tiny shift arrow */}
    <path d="M11 11.4 L 13.4 9.6" stroke="currentColor" stroke-width={sw * 0.8} stroke-linecap="round" />
    <path d="M13.4 9.6 L 12.5 9.4 M13.4 9.6 L 13.2 10.5" stroke="currentColor" stroke-width={sw * 0.8} stroke-linecap="round" />
    {/* new equilibrium */}
    <circle cx="14.6" cy="9.4" r={sw * 1.2} fill="currentColor" />
  </svg>
)}

{id === 'cross-wedge' && (
  <svg {...common}>
    {/* filled wedge (deadweight / surplus triangle) */}
    <path d="M12 12 L 4 4 L 4 20 Z" fill="currentColor" opacity="0.18" />
    {/* the two curves on top */}
    <line x1="3" y1="20" x2="21" y2="4" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="3" y1="4" x2="21" y2="20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'cross-arrows' && (
  <svg {...common}>
    {/* supply arrow heading up-right */}
    <line x1="4" y1="20" x2="20" y2="4" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <path d="M16.5 4 L 20 4 L 20 7.5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" fill="none" />
    {/* demand arrow heading down-right */}
    <line x1="4" y1="4" x2="20" y2="20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <path d="M20 16.5 L 20 20 L 16.5 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" fill="none" />
    {/* meeting point */}
    <circle cx="12" cy="12" r={sw * 1.4} fill="currentColor" />
  </svg>
)}

{id === 'cross-halo' && (
  <svg {...common}>
    {/* the X */}
    <line x1="3" y1="20" x2="21" y2="4" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    <line x1="3" y1="4" x2="21" y2="20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* halo ring around equilibrium */}
    <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width={sw * 0.85} fill="none" opacity="0.55" />
    <circle cx="12" cy="12" r={sw * 1.2} fill="currentColor" />
  </svg>
)}

{/* INFLECTION family */}
{id === 'inflection-tangent' && (
  <svg {...common}>
    {/* axis */}
    <line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="0.8" opacity="0.25" stroke-linecap="round" />
    {/* S-curve */}
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    {/* tangent line at the inflection point */}
    <line x1="6.5" y1="16" x2="17.5" y2="8" stroke="currentColor" stroke-width={sw * 0.85} stroke-linecap="round" stroke-dasharray="1.6 1.8" opacity="0.7" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'inflection-twin' && (
  <svg {...common}>
    {/* two mirrored S-curves crossing at centre */}
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <path d="M3 5 C 7 5, 9 12, 12 12 C 15 12, 17 19, 21 19" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" opacity="0.55" />
    <circle cx="12" cy="12" r={sw * 1.4} fill="currentColor" />
  </svg>
)}

{id === 'inflection-grid' && (
  <svg {...common}>
    {/* faint grid */}
    <g stroke="currentColor" stroke-width="0.6" opacity="0.18">
      <line x1="3" y1="6" x2="21" y2="6" />
      <line x1="3" y1="12" x2="21" y2="12" />
      <line x1="3" y1="18" x2="21" y2="18" />
      <line x1="3" y1="3" x2="3" y2="21" />
      <line x1="12" y1="3" x2="12" y2="21" />
      <line x1="21" y1="3" x2="21" y2="21" />
    </g>
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'inflection-ribbon' && (
  <svg {...common}>
    {/* parallel guide curve (ribbon) */}
    <path d="M3 16 C 7 16, 9 9, 12 9 C 15 9, 17 2, 21 2" stroke="currentColor" stroke-width={sw * 0.7} stroke-linecap="round" fill="none" opacity="0.35" />
    <path d="M3 22 C 7 22, 9 15, 12 15 C 15 15, 17 8, 21 8" stroke="currentColor" stroke-width={sw * 0.7} stroke-linecap="round" fill="none" opacity="0.35" />
    {/* main S */}
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw * 1.15} stroke-linecap="round" fill="none" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'inflection-mirror' && (
  <svg {...common}>
    {/* axis */}
    <line x1="2" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="0.8" opacity="0.25" stroke-linecap="round" />
    {/* upper S */}
    <path d="M3 12 C 7 12, 9 5, 12 5 C 12 5, 12 5, 12 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" opacity="0.55" />
    <path d="M3 19 C 7 19, 9 12, 12 12 C 15 12, 17 5, 21 5" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <path d="M12 19 C 15 19, 17 12, 21 12" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" opacity="0.55" />
    <circle cx="12" cy="12" r={sw * 1.4} fill="currentColor" />
  </svg>
)}

{/* LATTICE family */}
{id === 'lattice-path' && (
  <svg {...common}>
    {/* faint full lattice */}
    <g fill="currentColor" opacity="0.3">
      <circle cx="6" cy="18" r={sw * 0.8} />
      <circle cx="12" cy="18" r={sw * 0.8} />
      <circle cx="18" cy="18" r={sw * 0.8} />
      <circle cx="6" cy="12" r={sw * 0.8} />
      <circle cx="12" cy="12" r={sw * 0.8} />
      <circle cx="18" cy="12" r={sw * 0.8} />
      <circle cx="6" cy="6" r={sw * 0.8} />
      <circle cx="12" cy="6" r={sw * 0.8} />
      <circle cx="18" cy="6" r={sw * 0.8} />
    </g>
    {/* diagonal connecting line BL → TR */}
    <line x1="6" y1="18" x2="18" y2="6" stroke="currentColor" stroke-width={sw} stroke-linecap="round" />
    {/* lit path nodes */}
    <circle cx="6" cy="18" r={sw * 1.3} fill="currentColor" />
    <circle cx="12" cy="12" r={sw * 1.3} fill="currentColor" />
    <circle cx="18" cy="6" r={sw * 1.5} fill="currentColor" />
  </svg>
)}

{id === 'lattice-spread' && (
  <svg {...common}>
    {/* origin (BL) brightest, fading outward */}
    <g fill="currentColor">
      <circle cx="6" cy="18" r={sw * 1.5} />
      <circle cx="12" cy="18" r={sw * 1.1} opacity="0.75" />
      <circle cx="6" cy="12" r={sw * 1.1} opacity="0.75" />
      <circle cx="18" cy="18" r={sw * 0.95} opacity="0.5" />
      <circle cx="12" cy="12" r={sw * 0.95} opacity="0.5" />
      <circle cx="6" cy="6" r={sw * 0.95} opacity="0.5" />
      <circle cx="18" cy="12" r={sw * 0.8} opacity="0.3" />
      <circle cx="12" cy="6" r={sw * 0.8} opacity="0.3" />
      <circle cx="18" cy="6" r={sw * 0.7} opacity="0.2" />
    </g>
  </svg>
)}

{id === 'lattice-hex' && (
  <svg {...common}>
    {/* hexagonal arrangement: 1 centre + 6 around */}
    <g fill="currentColor">
      <circle cx="12" cy="4" r={sw * 1} opacity="0.55" />
      <circle cx="19" cy="8" r={sw * 1} opacity="0.7" />
      <circle cx="19" cy="16" r={sw * 1} opacity="0.7" />
      <circle cx="12" cy="20" r={sw * 1} opacity="0.55" />
      <circle cx="5" cy="16" r={sw * 1} opacity="0.55" />
      <circle cx="5" cy="8" r={sw * 1} opacity="0.55" />
      <circle cx="12" cy="12" r={sw * 1.6} />
    </g>
  </svg>
)}

{id === 'lattice-ring' && (
  <svg {...common}>
    {/* faint ring */}
    <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="0.8" opacity="0.25" fill="none" />
    {/* 6 dots on ring + centre */}
    <g fill="currentColor">
      <circle cx="12" cy="4" r={sw * 1} opacity="0.7" />
      <circle cx="18.93" cy="8" r={sw * 1} opacity="0.7" />
      <circle cx="18.93" cy="16" r={sw * 1.2} />
      <circle cx="12" cy="20" r={sw * 1} opacity="0.7" />
      <circle cx="5.07" cy="16" r={sw * 1} opacity="0.55" />
      <circle cx="5.07" cy="8" r={sw * 1} opacity="0.55" />
      <circle cx="12" cy="12" r={sw * 1.4} />
    </g>
  </svg>
)}

{id === 'lattice-pulse' && (
  <svg {...common}>
    {/* full lattice, all nodes dim */}
    <g fill="currentColor" opacity="0.32">
      <circle cx="6" cy="18" r={sw * 0.9} />
      <circle cx="12" cy="18" r={sw * 0.9} />
      <circle cx="18" cy="18" r={sw * 0.9} />
      <circle cx="6" cy="12" r={sw * 0.9} />
      <circle cx="18" cy="12" r={sw * 0.9} />
      <circle cx="6" cy="6" r={sw * 0.9} />
      <circle cx="12" cy="6" r={sw * 0.9} />
      <circle cx="18" cy="6" r={sw * 0.9} />
    </g>
    {/* central node lit + halo ring (the pulse) */}
    <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width={sw * 0.7} fill="none" opacity="0.45" />
    <circle cx="12" cy="12" r={sw * 1.7} fill="currentColor" />
  </svg>
)}

{/* FRONTIER (PPF) family */}
{id === 'frontier-ticks' && (
  <svg {...common}>
    {/* axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.9" opacity="0.35" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.9" opacity="0.35" stroke-linecap="round" />
    {/* tick marks */}
    <g stroke="currentColor" stroke-width="0.8" opacity="0.35">
      <line x1="4" y1="14" x2="2.8" y2="14" />
      <line x1="4" y1="8" x2="2.8" y2="8" />
      <line x1="10" y1="20" x2="10" y2="21.2" />
      <line x1="16" y1="20" x2="16" y2="21.2" />
    </g>
    <path d="M4 4 C 14 4, 20 10, 20 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <circle cx="14.2" cy="7.2" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'frontier-dual' && (
  <svg {...common}>
    {/* axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* inner (current) frontier */}
    <path d="M4 9 C 9 9, 14 14, 14 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" opacity="0.55" />
    {/* outer (expanded) frontier */}
    <path d="M4 4 C 14 4, 20 10, 20 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    {/* growth arrow */}
    <path d="M11 12.5 L 14.6 8.2" stroke="currentColor" stroke-width={sw * 0.8} stroke-linecap="round" />
    <path d="M14.6 8.2 L 13.5 8.1 M14.6 8.2 L 14.5 9.3" stroke="currentColor" stroke-width={sw * 0.8} stroke-linecap="round" />
  </svg>
)}

{id === 'frontier-radial' && (
  <svg {...common}>
    {/* axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* radial guide from origin to point */}
    <line x1="4" y1="20" x2="14.2" y2="7.2" stroke="currentColor" stroke-width={sw * 0.8} stroke-dasharray="1.4 1.6" opacity="0.55" stroke-linecap="round" />
    {/* PPF arc */}
    <path d="M4 4 C 14 4, 20 10, 20 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" fill="none" />
    <circle cx="14.2" cy="7.2" r={sw * 1.3} fill="currentColor" />
  </svg>
)}

{id === 'frontier-segments' && (
  <svg {...common}>
    {/* axes */}
    <line x1="4" y1="20" x2="21" y2="20" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    <line x1="4" y1="20" x2="4" y2="3" stroke="currentColor" stroke-width="0.8" opacity="0.3" stroke-linecap="round" />
    {/* polyline approximation of frontier (3 segments) */}
    <path d="M4 5 L 11 6.5 L 17 11 L 20 20" stroke="currentColor" stroke-width={sw} stroke-linecap="round" stroke-linejoin="round" fill="none" />
    {/* node at each kink */}
    <g fill="currentColor">

{
  "name": "tsholosetati-web",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "npm run build:demos && astro build && pagefind --site dist",
    "build:demos": "npm run build:sharp-sharp && npm run build:policy-prism",
    "build:sharp-sharp": "npm --prefix demos-src/sharp-sharp run build",
    "build:policy-prism": "npm --prefix demos-src/policy-prism run build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "embed": "tsx scripts/build-embeddings.ts",
    "summarize": "tsx scripts/ai-summarize.ts",
    "import:linkedin": "node scripts/import-linkedin.mjs",
    "import:linkedin:force": "node scripts/import-linkedin.mjs --force"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.0.3",
    "@astrojs/rss": "^4.0.10",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.1",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.9",
    "lenis": "^1.1.20",
    "motion": "^11.15.0",
    "pagefind": "^1.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2"
  }
}
